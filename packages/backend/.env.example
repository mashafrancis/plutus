# Set Convex environment variables
# npx convex env set BETTER_AUTH_SECRET=$(openssl rand -base64 32)
# npx convex env set SITE_URL http://localhost:3000
# npx convex env set GOOGLE_CLIENT_ID=your-google-client-id
# npx convex env set GOOGLE_CLIENT_SECRET=your-google-client-secret
#
# Google OAuth: In Google Cloud Console > Credentials > Authorized redirect URIs,
# add: <SITE_URL>/api/auth/callback/google
# e.g. http://localhost:3000/api/auth/callback/google
#
# Deployment used by `npx convex dev`
CONVEX_DEPLOYMENT=

# Web app Convex URL
VITE_CONVEX_URL=
# Same as VITE_CONVEX_URL but ends in .site
VITE_CONVEX_SITE_URL=
# Web app URL for authentication
SITE_URL=

BETTER_AUTH_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=