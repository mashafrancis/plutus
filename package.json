{
  "name": "tanstack-effect-convex",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "format": "vp fmt",
    "prepare": "vp config",
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F @tanstack-effect-convex/backend dev",
    "dev:setup": "turbo -F @tanstack-effect-convex/backend dev:setup",
    "update": "pnpm dlx taze -r -I patch"
  },
  "dependencies": {
    "@tanstack-effect-convex/env": "workspace:*",
    "dotenv": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.10",
    "@tanstack-effect-convex/config": "workspace:*",
    "@types/node": "catalog:",
    "turbo": "^2.8.17",
    "typescript": "catalog:",
    "ultracite": "6.5.1",
    "vite-plus": "catalog:"
  },
  "packageManager": "pnpm@10.32.1"
}
